# Copy to `.env` or `.env.local` (local overrides). The dev server loads both.
# Quick local DB: `docker compose up -d` (see repo root docker-compose.yml), then `pnpm db:migrate`.
#
# ── Server ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database (Railway MySQL) ─────────────────────────────────────────────
# Copy the "MySQL URL" / DATABASE_URL from the Railway MySQL service (Variables tab).
# Local dev: point this at the SAME URL as production to see live articles in /admin.
# WARNING: your machine will read/write the production database — back up first if unsure.
# DATABASE_URL=mysql://user:password@host:3306/railway
#
# Railway / many cloud MySQL hosts require TLS from outside the VPC:
# DATABASE_SSL=true
# If you get certificate errors, try (less strict — dev only):
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_URL=mysql://user:password@host:3306/railway

# ── Session Secret ───────────────────────────────────────────────────────
# Any long random string. Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_secret

# ── Admin Credentials ────────────────────────────────────────────────────
# Your login email and password for /admin/login
ADMIN_EMAIL=monica@example.com
ADMIN_PASSWORD=replace_with_strong_password

# ── AI Gateway (LLM translation + cover image generation) ────────────────
AI_GATEWAY_API_KEY=your_ai_gateway_key

# ── AWS S3 (article images & cover photos) ───────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
# Optional: custom CDN/domain in front of S3 (leave blank to use default S3 URL)
S3_PUBLIC_BASE_URL=

# Optional (map / notifications / legacy integrations)
FORGE_API_URL=
FORGE_API_KEY=

# Optional Umami analytics (omit locally — both required if you enable)
# VITE_ANALYTICS_ENDPOINT=https://your-umami.example.com
# VITE_ANALYTICS_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
