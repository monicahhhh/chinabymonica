# ── Server ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database (Railway MySQL) ─────────────────────────────────────────────
# Copy the "MySQL URL" from the Railway MySQL service dashboard
DATABASE_URL=mysql://user:password@host:3306/railway

# ── Session Secret ───────────────────────────────────────────────────────
# Any long random string. Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_secret

# ── Admin Credentials ────────────────────────────────────────────────────
# Your login email and password for /admin/login
ADMIN_EMAIL=monica@example.com
ADMIN_PASSWORD=replace_with_strong_password

# ── AI Gateway (LLM translation + cover image generation) ────────────────
AI_GATEWAY_API_KEY=your_ai_gateway_key

# ── AWS S3 (article images & cover photos) ───────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
# Optional: custom CDN/domain in front of S3 (leave blank to use default S3 URL)
S3_PUBLIC_BASE_URL=
